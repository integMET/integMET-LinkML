@prefix dc: <http://purl.org/dc/terms/> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix integmet: <https://example.org/integmet/ontology/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

integmet:analysisGroup a owl:ObjectProperty ;
    rdfs:label "analysis group"@en ;
    rdfs:comment "Links a study to an analysis-group resource representing a study file or file grouping."@en ;
    rdfs:domain integmet:Study ;
    rdfs:isDefinedBy integmet: ;
    rdfs:range integmet:AnalysisGroup .

integmet:category a owl:DatatypeProperty ;
    rdfs:label "category"@en ;
    rdfs:comment "Middle-level category in the IntegMet study category hierarchy."@en ;
    rdfs:domain integmet:StudyCategoryClassification ;
    rdfs:isDefinedBy integmet: ;
    rdfs:range rdf:langString .

integmet:categoryBranch a owl:DatatypeProperty ;
    rdfs:label "category branch"@en ;
    rdfs:comment "Top-level branch in the IntegMet study category hierarchy."@en ;
    rdfs:domain integmet:StudyCategoryClassification ;
    rdfs:isDefinedBy integmet: ;
    rdfs:range rdf:langString .

integmet:categoryInfo a owl:ObjectProperty ;
    rdfs:label "category info"@en ;
    rdfs:comment "IntegMet-curated category metadata assigned to a study based on cited source information."@en ;
    rdfs:domain integmet:Study ;
    rdfs:isDefinedBy integmet: ;
    rdfs:range integmet:StudyCategoryClassification ;
    rdfs:subPropertyOf dcat:theme .

integmet:derivedAbstract a owl:DatatypeProperty ;
    rdfs:label "derived abstract"@en ;
    rdfs:comment "A study summary generated by IntegMet from abstract and description metadata in cited source resources."@en ;
    rdfs:domain integmet:Study ;
    rdfs:isDefinedBy integmet: ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf schema:abstract .

integmet:derivedDescription a owl:DatatypeProperty ;
    rdfs:label "derived description"@en ;
    rdfs:comment "A study description generated by IntegMet from abstract and description metadata in cited source resources."@en ;
    rdfs:domain integmet:Study ;
    rdfs:isDefinedBy integmet: ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf schema:description .

integmet:findings a owl:DatatypeProperty ;
    rdfs:label "findings"@en ;
    rdfs:comment "Finding summary curated for an IntegMet study."@en ;
    rdfs:domain integmet:Study ;
    rdfs:isDefinedBy integmet: ;
    rdfs:range rdfs:Literal .

integmet:graphGroup a owl:DatatypeProperty ;
    rdfs:label "graph group"@en ;
    rdfs:comment "A coarse study grouping label used within IntegMet for graph construction and downstream grouping workflows."@en ;
    rdfs:domain integmet:Study ;
    rdfs:isDefinedBy integmet: ;
    rdfs:range rdf:langString .

integmet:hasAnnotatedGOTerm a owl:ObjectProperty ;
    rdfs:label "has annotated GO term"@en ;
    rdfs:comment "Relates an IntegMet study to a Gene Ontology term assigned by annotation or downstream analysis of the source project metadata."@en ;
    rdfs:domain integmet:Study ;
    rdfs:isDefinedBy integmet: ;
    rdfs:range rdfs:Resource ;
    rdfs:subPropertyOf dc:subject .

integmet:hasAnnotatedMeSHTerm a owl:ObjectProperty ;
    rdfs:label "has annotated MeSH term"@en ;
    rdfs:comment "Relates an IntegMet study to a MeSH term assigned by annotation or downstream analysis of the source project metadata."@en ;
    rdfs:domain integmet:Study ;
    rdfs:isDefinedBy integmet: ;
    rdfs:range rdfs:Resource ;
    rdfs:subPropertyOf dc:subject .

integmet:hasAnnotatedNCBIGene a owl:ObjectProperty ;
    rdfs:label "has annotated NCBI Gene"@en ;
    rdfs:comment "Relates an IntegMet study to an NCBI Gene resource assigned by annotation or downstream analysis of the source project metadata."@en ;
    rdfs:domain integmet:Study ;
    rdfs:isDefinedBy integmet: ;
    rdfs:range rdfs:Resource ;
    rdfs:subPropertyOf dc:subject .

integmet:hasAnnotatedOMIMEntry a owl:ObjectProperty ;
    rdfs:label "has annotated OMIM entry"@en ;
    rdfs:comment "Relates an IntegMet study to an OMIM entry assigned by annotation or downstream analysis of the source project metadata."@en ;
    rdfs:domain integmet:Study ;
    rdfs:isDefinedBy integmet: ;
    rdfs:range rdfs:Resource ;
    rdfs:subPropertyOf dc:subject .

integmet:hasRetentionIndex a owl:DatatypeProperty ;
    rdfs:label "has retention index"@en ;
    rdfs:comment "Boolean flag indicating that the study includes retention index information."@en ;
    rdfs:domain integmet:Study ;
    rdfs:isDefinedBy integmet: ;
    rdfs:range xsd:boolean .

integmet:isLipidomics a owl:DatatypeProperty ;
    rdfs:label "is lipidomics"@en ;
    rdfs:comment "Boolean flag indicating that the study contains lipidomics-related source data."@en ;
    rdfs:domain integmet:Study ;
    rdfs:isDefinedBy integmet: ;
    rdfs:range xsd:boolean .

integmet:observations a owl:DatatypeProperty ;
    rdfs:label "observations"@en ;
    rdfs:comment "Observation summary curated for an IntegMet study."@en ;
    rdfs:domain integmet:Study ;
    rdfs:isDefinedBy integmet: ;
    rdfs:range rdfs:Literal .

integmet:organism a owl:ObjectProperty ;
    rdfs:label "organism"@en ;
    rdfs:comment "Relates a source-derived organism annotation set to a normalized organism resource, typically an NCBI Taxonomy identifier."@en ;
    rdfs:domain integmet:SourceDerivedOrganismAnnotationSet ;
    rdfs:isDefinedBy integmet: ;
    rdfs:range rdfs:Resource .

integmet:organismAnnotation a owl:ObjectProperty ;
    rdfs:label "organism annotation"@en ;
    rdfs:comment "Relates an IntegMet study to a source-derived organism annotation set node that captures one or more organism values together with provenance to the cited source project."@en ;
    rdfs:domain integmet:Study ;
    rdfs:isDefinedBy integmet: ;
    rdfs:range integmet:SourceDerivedOrganismAnnotationSet .

integmet:subcategory a owl:DatatypeProperty ;
    rdfs:label "subcategory"@en ;
    rdfs:comment "Lowest-level category in the IntegMet study category hierarchy."@en ;
    rdfs:domain integmet:StudyCategoryClassification ;
    rdfs:isDefinedBy integmet: ;
    rdfs:range rdf:langString .

integmet:unresolvedTaxonomy a owl:DatatypeProperty ;
    rdfs:label "unresolved taxonomy"@en ;
    rdfs:comment "A taxonomy string captured from a cited source when it could not be normalized to an NCBI Taxonomy identifier."@en ;
    rdfs:domain integmet:SourceDerivedOrganismAnnotationSet ;
    rdfs:isDefinedBy integmet: ;
    rdfs:range xsd:string .

integmet:AnalysisGroup a owl:Class ;
    rdfs:label "Analysis group"@en ;
    rdfs:comment "A data-file level grouping within an IntegMet study."@en ;
    rdfs:isDefinedBy integmet: .

integmet:SourceDerivedOrganismAnnotationSet a owl:Class ;
    rdfs:label "source-derived organism annotation set"@en ;
    rdfs:comment "A source-derived set of organism annotations attached to an IntegMet study and explicitly represented as having been obtained from the cited source project rather than inferred independently within IntegMet."@en ;
    rdfs:isDefinedBy integmet: .

integmet:StudyCategoryClassification a owl:Class ;
    rdfs:label "Study category classification"@en ;
    rdfs:comment "Structured category metadata with branch, category, and optional subcategory assigned by IntegMet."@en ;
    rdfs:isDefinedBy integmet: .

integmet:Study a owl:Class ;
    rdfs:label "IntegMet study"@en ;
    rdfs:comment "A study resource curated in the IntegMet dataset."@en ;
    rdfs:isDefinedBy integmet: ;
    rdfs:subClassOf dcat:Dataset .

integmet: a owl:Ontology ;
    rdfs:label "IntegMet ontology"@en ;
    dc:created "2026-03-27"^^xsd:date ;
    dc:creator "IntegMet project"@en ;
    dc:description "Ontology for IntegMet-specific study metadata, derived textual summaries, category assignments, annotation links, provenance, and related structural relations."@en ;
    dc:title "IntegMet Ontology"@en ;
    rdfs:comment "Custom RDF vocabulary used for IntegMet-specific study metadata and structural relations."@en ;
    owl:versionInfo "0.1.9" .

